# Production site URL (no trailing slash). Used for sitemap, robots, Open Graph, and canonical URLs.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: override default 3600s cache for RSS fetches (seconds).
# RSS_REVALIDATE_SECONDS=3600

# Optional: Kit (ConvertKit) public API key for /api/newsletter (Settings → Advanced in Kit).
# On-page signup posts directly to Kit from the browser; this key is only for the API route.
# KIT_API_KEY=your_public_api_key
